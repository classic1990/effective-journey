rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }
    function isValidMovieData() {
      return request.resource.data.keys().hasAll(['title', 'year', 'youtubeId']) &&
             request.resource.data.title is string &&
             request.resource.data.title.size() > 0 &&
             request.resource.data.year is int &&
             request.resource.data.year >= 1900 &&
             request.resource.data.year <= 2030 &&
             request.resource.data.youtubeId is string &&
             request.resource.data.youtubeId.size() > 0;
    }
    function isValidUserData() {
      return request.resource.data.keys().hasAll(['email', 'createdAt']) &&
             request.resource.data.email is string &&
             request.resource.data.email.matches('.+@.+\\..+');
    }

    // Movies collection - readable by all, writable only by admin
    match /movies/{movieId} {
      allow read: if true;
      allow create: if isAdmin() && isValidMovieData();
      allow update: if isAdmin() && isValidMovieData();
      allow delete: if isAdmin();
      
      // Indexes for queries
      allow list: if true;
    }

    // Series collection - readable by all, writable only by admin
    match /series/{seriesId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Users collection - user can read/write only their own doc; admin can read/write all
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUserData();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Stats collection - readable by all; write only admin
    match /stats/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin logs - only admin can read/write
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // User activity logs - user can read their own; admin can read all
    match /userActivity/{activityId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isOwner(resource.data.userId) || isAdmin();
    }

    // Categories collection - readable by all; admin can manage
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Settings collection - only admin can read/write
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Cache collection for frequently accessed data
    match /cache/{cacheId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
